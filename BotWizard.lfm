object frmBotWizard: TfrmBotWizard
  Left = 300
  Height = 420
  Top = 200
  Width = 360
  BorderStyle = bsDialog
  Caption = 'New Bot'
  Position = poMainFormCenter
  OnCreate = FormCreate
  object lblStrategy: TLabel
    Left = 16
    Height = 15
    Top = 16
    Width = 50
    Caption = 'Strategy:'
  end
  object cbxStrategy: TComboBox
    Left = 16
    Height = 23
    Top = 34
    Width = 320
    Style = csDropDownList
    OnChange = cbxStrategyChange
    TabOrder = 0
  end
  object lblUnderlying: TLabel
    Left = 16
    Height = 15
    Top = 68
    Width = 60
    Caption = 'Underlying:'
  end
  object edtUnderlying: TEdit
    Left = 16
    Height = 23
    Top = 86
    Width = 320
    TabOrder = 1
  end
  object lblLots: TLabel
    Left = 16
    Height = 15
    Top = 120
    Width = 25
    Caption = 'Lots:'
  end
  object edtLots: TSpinEdit
    Left = 16
    Height = 23
    Top = 138
    Width = 80
    MinValue = 1
    MaxValue = 100
    Value = 1
    TabOrder = 2
  end
  object lblWarmup: TLabel
    Left = 120
    Height = 15
    Top = 120
    Width = 80
    Caption = 'Warmup Ticks:'
  end
  object edtWarmup: TSpinEdit
    Left = 120
    Height = 23
    Top = 138
    Width = 80
    MinValue = 0
    MaxValue = 10000
    Value = 50
    TabOrder = 3
  end
  object lblParams: TLabel
    Left = 16
    Height = 15
    Top = 176
    Width = 65
    Caption = 'Parameters:'
  end
  object gridParams: TStringGrid
    Left = 16
    Height = 160
    Top = 194
    Width = 320
    ColCount = 2
    FixedCols = 0
    RowCount = 1
    FixedRows = 1
    TabOrder = 4
  end
  object btnOK: TButton
    Left = 168
    Height = 30
    Top = 370
    Width = 80
    Caption = 'OK'
    Default = True
    OnClick = btnOKClick
    TabOrder = 5
  end
  object btnCancel: TButton
    Left = 256
    Height = 30
    Top = 370
    Width = 80
    Caption = 'Cancel'
    Cancel = True
    OnClick = btnCancelClick
    TabOrder = 6
  end
end
