<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
        <ProjectVersion>19.5</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <MainSource>TopazDashboard.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Application</AppType>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base'">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug'">
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
        <DCC_DebugInformation>2</DCC_DebugInformation>
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release'">
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;$(DCC_Namespace)</DCC_Namespace>
        <DCC_UnitSearchPath>modules;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <DCC_ExeOutput>.\bin</DCC_ExeOutput>
        <DCC_DcuOutput>.\lib\dcu</DCC_DcuOutput>
        <SanitizedProjectName>TopazDashboard</SanitizedProjectName>
        <DCC_E>false</DCC_E>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="MainForm.pas">
            <Form>frmDashboard</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="BotWizard.pas">
            <Form>frmBotWizard</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="modules\Apollo.Broker.pas"/>
        <DCCReference Include="modules\Topaz.RingBuffer.pas"/>
        <DCCReference Include="modules\Topaz.EventTypes.pas"/>
        <DCCReference Include="modules\Topaz.Strategy.pas"/>
        <DCCReference Include="modules\Topaz.Indicators.pas"/>
        <DCCReference Include="modules\Topaz.BlackScholes.pas"/>
        <DCCReference Include="modules\Topaz.Risk.pas"/>
        <DCCReference Include="modules\Topaz.Bracket.pas"/>
        <DCCReference Include="modules\Topaz.State.pas"/>
        <DCCReference Include="modules\Topaz.Reconciler.pas"/>
        <DCCReference Include="modules\Topaz.Metrics.pas"/>
        <DCCReference Include="modules\Topaz.Candles.pas"/>
        <DCCReference Include="modules\Topaz.Execution.pas"/>
        <DCCReference Include="modules\Topaz.Session.pas"/>
        <DCCReference Include="modules\Topaz.Intents.pas"/>
        <DCCReference Include="modules\Topaz.Backtest.pas"/>
        <DCCReference Include="modules\Topaz.ParamSweep.pas"/>
        <DCCReference Include="modules\Topaz.ConfigLoader.pas"/>
        <DCCReference Include="modules\Topaz.Alerts.pas"/>
        <DCCReference Include="modules\Topaz.IVAnalysis.pas"/>
        <DCCReference Include="modules\Topaz.PortfolioGreeks.pas"/>
        <DCCReference Include="modules\Topaz.OptionTemplates.pas"/>
        <DCCReference Include="modules\Topaz.Adjustment.pas"/>
        <DCCReference Include="modules\XGBoost.Wrapper.pas"/>
        <DCCReference Include="Topaz.Strategy.OptionScalper.pas"/>
        <DCCReference Include="Topaz.Strategy.MLStrategy.pas"/>
        <DCCReference Include="Topaz.Strategy.KalmanScalper.pas"/>
        <DCCReference Include="Topaz.Strategy.Momentum.pas"/>
        <DCCReference Include="Topaz.Strategy.DoubleRSI.pas"/>
        <DCCReference Include="Topaz.Strategy.MeanReversion.pas"/>
        <DCCReference Include="Topaz.Strategy.ORB.pas"/>
        <DCCReference Include="Topaz.Strategy.ExpiryGamma.pas"/>
        <DCCReference Include="Topaz.Strategy.CompositeScalper.pas"/>
        <DCCReference Include="Topaz.Strategy.GammaScalp.pas"/>
        <DCCReference Include="Topaz.Strategy.OptionsScalper.pas"/>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">TopazDashboard.dpr</Source>
                </Source>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">False</Platform>
                <Platform value="Win64">True</Platform>
            </Platforms>
        </BorlandProject>
    </ProjectExtensions>
</Project>
